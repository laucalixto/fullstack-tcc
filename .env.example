# ── Server ────────────────────────────────────────────────────────────────────

# TCP port the HTTP/WebSocket server listens on (default: 3001)
PORT=3001

# Allowed CORS origin — React dev server or Cloud Run client URL
CLIENT_URL=http://localhost:5173

# JWT signing secret — MUST be a strong random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# MongoDB connection string (MongoDB Atlas or local)
MONGODB_URI=mongodb://localhost:27017/safety_board

# ── Client (Vite build-time) ───────────────────────────────────────────────────

# Full URL of the server — injected at build time by Vite
# Example for local dev: http://localhost:3001
# Example for Cloud Run: https://safety-board-server-<hash>-ue.a.run.app
VITE_SERVER_URL=http://localhost:3001

# ── GCP / GitHub Actions (CI/CD secrets — do not commit real values) ──────────

# GCP project ID (used in deploy.yml)
# GCP_PROJECT_ID=my-gcp-project-id

# Workload Identity Federation provider resource name
# GCP_WORKLOAD_IDENTITY_PROVIDER=projects/123/locations/global/workloadIdentityPools/github/providers/github

# Service account email with roles: Artifact Registry Writer + Cloud Run Admin
# GCP_SERVICE_ACCOUNT=github-actions@my-gcp-project-id.iam.gserviceaccount.com

# Cloud Run client URL (set after first deploy, used as CLIENT_URL in server)
# CLIENT_URL=https://safety-board-client-<hash>-ue.a.run.app

# VITE_SERVER_URL used at build time in CD pipeline
# VITE_SERVER_URL=https://safety-board-server-<hash>-ue.a.run.app
