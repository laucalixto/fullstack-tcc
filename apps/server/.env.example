# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:5173

# ─── Segurança ────────────────────────────────────────────────────────────────
# Troque por um segredo forte em produção (min 32 chars)
JWT_SECRET=troque-por-segredo-forte-em-producao

# Custo do bcrypt — valores altos aumentam segurança e tempo de hash
# 12 é padrão seguro; use 10 em dev se quiser mais velocidade
BCRYPT_ROUNDS=12

# ─── MongoDB ─────────────────────────────────────────────────────────────────
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/safety-board
# Local: mongodb://localhost:27017/safety-board
# Se omitido, servidor roda em modo in-memory (dados perdidos ao reiniciar)
MONGODB_URI=mongodb://localhost:27017/safety-board
